# DeSEC Manager — Root .htaccess
# Webserver: Apache 2.4+ mit mod_rewrite, mod_headers (optional)

# Verzeichnislistings und Signaturen deaktivieren
Options -Indexes -MultiViews
ServerSignature Off

# ── Schutz sensibler Verzeichnisse ───────────────────────────────────────────
# Direktzugriff auf PHP-Code, Konfiguration, vendor/, Locale, SQL-Skripte etc.
# wird mit HTTP 403 abgewiesen — auch wenn mod_rewrite deaktiviert ist.

<IfModule mod_authz_core.c>
    <DirectoryMatch "^(.+/)?(src|config|vendor|locale|app|tests|sql|var)(/|$)">
        Require all denied
    </DirectoryMatch>
</IfModule>

# .env, composer.json, phpstan.neon etc. nie ausliefern
<FilesMatch "^(\.env|composer\.(json|lock)|phpstan\.neon|\.gitignore|\.gitattributes|README\.md|FRAMEWORKS\.md|PHP84_COMPATIBILITY\.md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# ── Routing: Alles über index.php ────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Installer direkt erreichbar lassen
    RewriteRule ^install(/.*)?$  install/index.php  [QSA,L]

    # Statische Dateien und echte Verzeichnisse direkt ausliefern
    RewriteCond %{REQUEST_FILENAME} -f  [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Alle anderen Anfragen → index.php (Front-Controller)
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ── Sicherheits-Header ───────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options  "nosniff"
    Header always set X-Frame-Options         "SAMEORIGIN"
    Header always set Referrer-Policy         "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection        "0"
    Header always set Permissions-Policy      "camera=(), microphone=(), geolocation=()"

    # HSTS nur aktivieren wenn HTTPS konfiguriert ist (Kommentar entfernen):
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
