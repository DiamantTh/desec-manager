{
    "name": "desec/manager",
    "description": "deSEC DNS Manager",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "doctrine/dbal": "^3.7",
        "guzzlehttp/guzzle": "^7.8",
        "laminas/laminas-diactoros": "^3.5",
        "mezzio/mezzio": "^3.20",
        "mezzio/mezzio-fastroute": "^3.11",
        "mezzio/mezzio-twigrenderer": "^2.14",
        "monolog/monolog": "^3.0",
        "php-di/php-di": "^7.1",
        "spomky-labs/otphp": "^11.4",
        "symfony/mailer": "^7.0",
        "twig/twig": "^3.0",
        "web-auth/webauthn-lib": "^5.2",
        "yosymfony/toml": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "phpstan": "phpstan analyse --configuration=phpstan.neon",
        "lint": "find src -name '*.php' -exec php -l {} \\;",
        "test": "phpunit",
        "analyse": "@phpstan"
    }
}
