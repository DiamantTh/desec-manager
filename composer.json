{
    "name": "desec/manager",
    "description": "deSEC DNS Manager",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "doctrine/dbal": "^3.7",
        "guzzlehttp/guzzle": "^7.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "phpstan": "phpstan analyse --configuration=phpstan.neon",
        "lint": "php -l src/*.php && find src -name '*.php' -exec php -l {} \\;",
        "test": "@phpstan"
    }
}
