{
    "name": "desec/manager",
    "description": "deSEC DNS Manager",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "ext-intl": "*",
        "doctrine/dbal": "^3.7",
        "guzzlehttp/guzzle": "^7.8",
        "laminas/laminas-diactoros": "^3.5",
        "laminas/laminas-filter": "^2.35",
        "laminas/laminas-i18n": "^2.28",
        "laminas/laminas-inputfilter": "^2.30",
        "laminas/laminas-permissions-rbac": "^3.4",
        "laminas/laminas-validator": "^2.64",
        "mezzio/mezzio": "^3.20",
        "mezzio/mezzio-csrf": "^1.3",
        "mezzio/mezzio-fastroute": "^3.11",
        "mezzio/mezzio-session": "^1.10",
        "mezzio/mezzio-session-ext": "^1.6",
        "mezzio/mezzio-twigrenderer": "^2.14",
        "monolog/monolog": "^3.0",
        "php-di/php-di": "^7.1",
        "psr/clock": "^1.0",
        "psr/simple-cache": "^3.0",
        "sentry/sentry": "^4.10",
        "spomky-labs/otphp": "^11.4",
        "symfony/cache": "^7.0",
        "symfony/console": "^7.0",
        "symfony/mailer": "^7.0",
        "twig/twig": "^3.0",
        "web-auth/webauthn-lib": "^5.2",
        "yosymfony/toml": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": ["src/functions.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.4.99",
            "ext-intl": "8.4.99"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "phpstan": "phpstan analyse --configuration=phpstan.neon",
        "lint": "find src -name '*.php' -exec php -l {} \\;",
        "test": "phpunit",
        "analyse": "@phpstan"
    }
}
