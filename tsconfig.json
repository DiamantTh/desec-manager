{
    "compilerOptions": {
        "target":                 "ES2020",
        "module":                 "ESNext",
        "moduleResolution":       "bundler",
        "lib":                    ["ES2020", "DOM", "DOM.Iterable"],
        "strict":                 true,
        "noImplicitAny":          true,
        "skipLibCheck":           true,
        "verbatimModuleSyntax":   true
    },
    "include":  ["themes/default/src/**/*"],
    "exclude":  ["node_modules"]
}
