parameters:
    level: 8
    phpVersion: 80400
    paths:
        - src
        - index.php
        - install.php
        - status.php
    excludePaths:
        - vendor
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Ignore missing config file issues (it's created during installation)
        - '#require\(\): Failed opening#'
        # Ignore collection types
        - '#Property App\\Entity\\.*Collection.*#'

        # =======================================================================
        # Doctrine ORM Attribute-Fehler ignorieren
        # Diese Attribute werden zur Dokumentation der Entitätsstruktur verwendet,
        # obwohl das Projekt Doctrine DBAL (nicht ORM) nutzt.
        # =======================================================================
        - '#Attribute class Doctrine\\ORM\\Mapping\\Column does not exist#'
        - '#Attribute class Doctrine\\ORM\\Mapping\\Entity does not exist#'
        - '#Attribute class Doctrine\\ORM\\Mapping\\Table does not exist#'
        - '#Attribute class Doctrine\\ORM\\Mapping\\Id does not exist#'
        - '#Attribute class Doctrine\\ORM\\Mapping\\GeneratedValue does not exist#'
        - '#Attribute class Doctrine\\ORM\\Mapping\\OneToMany does not exist#'
        - '#Attribute class Doctrine\\ORM\\Mapping\\ManyToOne does not exist#'
        - '#Attribute class Doctrine\\ORM\\Mapping\\JoinColumn does not exist#'

        # =======================================================================
        # Doctrine DBAL-Fehler ignorieren (Autoloader-Probleme)
        # Diese Fehler entstehen durch fehlende Vendor-Autoloader-Integration
        # =======================================================================
        - '#unknown class Doctrine\\DBAL\\Connection#'
        - '#unknown class Doctrine\\DBAL\\DriverManager#'
        - '#unknown class Doctrine\\DBAL\\Schema\\Schema#'
        - '#invalid type Doctrine\\DBAL\\Connection#'
        - '#has invalid return type Doctrine\\DBAL\\Connection#'

        # =======================================================================
        # Doctrine Collections-Fehler ignorieren
        # =======================================================================
        - '#unknown class Doctrine\\Common\\Collections\\Collection#'
        - '#unknown class Doctrine\\Common\\Collections\\ArrayCollection#'
        - '#Instantiated class Doctrine\\Common\\Collections\\ArrayCollection not found#'
        - '#has invalid return type Doctrine\\Common\\Collections\\Collection#'
        - '#Instantiated class App\\Entity\\ArrayCollection not found#'
        - '#has invalid return type App\\Entity\\Collection#'
        - '#unknown class App\\Entity\\Collection#'

        # =======================================================================
        # GuzzleHTTP-Fehler ignorieren (Autoloader-Probleme)
        # =======================================================================
        - '#unknown class GuzzleHttp\\Client#'
        - '#unknown class GuzzleHttp\\Exception\\GuzzleException#'
        - '#unknown class GuzzleHttp\\RequestOptions#'
        - '#Instantiated class GuzzleHttp\\Client not found#'
        - '#Caught class GuzzleHttp\\Exception\\GuzzleException not found#'

        # =======================================================================
        # Entity-Klassen-Fehler ignorieren (da DBAL statt ORM verwendet wird)
        # =======================================================================
        - '#Class App\\Entity\\Domain not found#'
        - '#Class App\\Entity\\UserRepository not found#'
        - '#Class App\\Entity\\ApiKeyRepository not found#'
        - '#invalid type App\\Entity\\Domain#'
        - '#unknown class App\\Entity\\Domain#'

        # =======================================================================
        # Schema-Fehler ignorieren (DBAL)
        # =======================================================================
        - '#Instantiated class Doctrine\\DBAL\\Schema\\Schema not found#'

        # =======================================================================
        # Entity-Properties ignorieren (ORM-Design)
        # Diese Properties sind Teil des Entity-Designs für zukünftige ORM-Nutzung.
        # Sie werden derzeit nicht verwendet, da DBAL statt ORM genutzt wird.
        # =======================================================================
        - '#Property App\\Entity\\WebAuthnCredential::\$[a-zA-Z]+ is unused#'
        - '#Property App\\Entity\\WebAuthnCredential::\$[a-zA-Z]+ is never read, only written#'
        - '#Property App\\Entity\\WebAuthnCredential::\$[a-zA-Z]+.* is never assigned.*#'
        - '#Property App\\Entity\\User::\$id \(int\|null\) is never assigned int#'
        - '#Property App\\Entity\\ApiKey::\$id \(int\|null\) is never assigned int#'
        - '#Property App\\Entity\\UserKey::\$id \(int\|null\) is never assigned int#'

        # =======================================================================
        # DatabaseConnection Null-Return ignorieren (gewolltes Verhalten)
        # =======================================================================
        - '#Method App\\Database\\DatabaseConnection::getConnection\(\) should return Doctrine\\DBAL\\Connection but returns#'
