# Beispielkonfiguration im YAML-Format / Example configuration in YAML format
# Die Werte entsprechen der PHP-Vorlage config.php.dist / Values mirror config.php.dist

# Datenbank / Database
database:
  host: ""              # Wird während der Installation gesetzt / Set during installation
  name: ""              # Name der Datenbank / Database name
  user: ""              # Datenbankbenutzer / Database user
  pass: ""              # Datenbankpasswort / Database password

# Sicherheit / Security
security:
  algo: argon2id        # Argon2id Hash-Algorithmus / Argon2id hash algorithm
  options:
    memory_cost: 65536  # 64MB Minimum für sensible Daten / 64MB minimum for sensitive data
    time_cost: 4        # 4 Iterationen / 4 iterations
    threads: 2          # 2 Threads / 2 threads

# Debug-Modus / Debug mode
debug: false

# Anwendungseinstellungen / Application settings
application:
  domain: ""            # z.B. "example.com" oder "localhost" / e.g. "example.com" or "localhost"
  name: "DeSEC Manager"
  webauthn_enabled: true  # Wird für ungültige TLDs deaktiviert / Turns false for invalid TLDs
  force_https: true        # Nur in Entwicklung auf false setzen / Only set to false during development
