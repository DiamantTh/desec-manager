# Lokale Konfigurationsüberschreibungen
# ======================================
# Diese Datei wird von Git ignoriert (.gitignore).
# Kopieren nach: config/config.local.toml
# Nur die Werte angeben, die von den Standardkonfigurationen abweichen.
# Die Standarddateien (app.toml, database.toml, mail.toml, security.toml) werden
# zuerst geladen; config.local.toml überschreibt mit array_replace_recursive().
#
# SECRETS: Passwörter und Schlüssel gehören entweder hierher (config.local.toml,
# gitignored) oder besser noch in Umgebungsvariablen:
#   DB_PASSWORD       — Datenbankpasswort
#   MAIL_PASSWORD     — SMTP-Passwort
#   ENCRYPTION_KEY    — 32-Byte-Key für libsodium-Verschlüsselung

[app]
debug  = true
domain = "localhost"
# theme = "default"

[database]
driver = "pdo_mysql"
host   = "localhost"
port   = 3306
name   = "desec_manager"
user   = "desec_manager"
# Passwort via Umgebungsvariable: export DB_PASSWORD="geheim"

[mail]
transport = "smtp"

[mail.smtp]
host = "localhost"
port = 1025        # Mailpit/Mailhog für lokale Entwicklung

[security]
# Lokal testweise erzeugen: php -r "echo sodium_bin2hex(random_bytes(32));"
# encryption_key = ""

[security.session]
secure = false     # Lokal ohne HTTPS: false setzen
