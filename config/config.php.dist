<?php
/**
 * Basis-Konfiguration — deSEC Manager
 *
 * Diese Datei dient als Vorlage. Die tatsächliche Konfiguration wird durch
 * install.php als config/config.php erzeugt und sollte NICHT in die
 * Versionskontrolle eingecheckt werden (steht in .gitignore).
 *
 * Alle Felder, die während der Installation gesetzt werden, sind mit
 * "Set during installation" / "Wird während der Installation gesetzt" markiert.
 */
return [

    // ─── Datenbank ───────────────────────────────────────────────────────────
    // Unterstützte Treiber: 'pdo_mysql' (Standard), 'pdo_sqlite'
    'database' => [
        'driver'    => 'pdo_mysql',    // pdo_mysql | pdo_sqlite
        'host'      => '',             // Set during installation
        'port'      => 3306,           // MySQL-Port (Standard 3306)
        'name'      => '',             // Set during installation (DB-Name)
        'user'      => '',             // Set during installation
        'pass'      => '',             // Set during installation
        'charset'   => 'utf8mb4',
        'collation' => 'utf8mb4_unicode_ci',
        // SQLite: nur 'path' relevant (alle anderen Felder werden ignoriert)
        // 'path'   => __DIR__ . '/../var/database.sqlite',
    ],

    // ─── Sicherheit ──────────────────────────────────────────────────────────
    'security' => [
        // Passwort-Hashing: Argon2id (empfohlen, OWASP-konform)
        'algo'    => PASSWORD_ARGON2ID,
        'options' => [
            'memory_cost' => 65536, // 64 MB – Minimum für sensible Daten
            'time_cost'   => 4,     // Iterationen
            'threads'     => 2,     // Parallele Threads
        ],
        // Verschlüsselungsschlüssel für API-Keys (Base64, gesetzt während Installation)
        // ACHTUNG: Änderungen machen alle gespeicherten API-Keys unlesbar!
        'encryption_key' => '', // Set during installation
    ],

    // ─── Anwendung ───────────────────────────────────────────────────────────
    'application' => [
        // Hostname ohne Protokoll, z. B. 'manager.example.com' oder 'localhost'
        'domain'          => '',           // Set during installation
        'name'            => 'DeSEC Manager',
        // WebAuthn erfordert HTTPS und eine gültige TLD.
        // Wird automatisch auf false gesetzt wenn Bedingungen nicht erfüllt sind.
        'webauthn_enabled' => true,
        // Erzwingt HTTPS-Umleitung. Nur in Entwicklungsumgebungen auf false setzen.
        'force_https'      => true,
    ],

    // ─── Theme ───────────────────────────────────────────────────────────────
    // Verfügbare eingebaute Themes: 'default', 'bulma'
    // Eigene Themes: Verzeichnis unter themes/{name}/ anlegen (siehe themes/svelte/ als Beispiel).
    // Das aktive Theme wird hier per Name referenziert.
    'theme' => [
        'name' => 'default', // 'default' = Hellblau+Grün, Light/Dark | 'bulma' = klassisches Bulma
    ],

    // ─── Debug ───────────────────────────────────────────────────────────────
    // Niemals in Produktion auf true setzen — gibt interne Fehler aus!
    'debug' => false,
];

