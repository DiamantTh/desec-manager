# Beispielkonfiguration im TOML-Format — deSEC Manager
# Werte orientieren sich an config.php.dist
# Diese Datei dient nur als Referenz; die tatsächliche Konfiguration ist config.php

[database]
# Treiber: "pdo_mysql" (Standard) oder "pdo_sqlite"
driver     = "pdo_mysql"
# Set during installation
host       = ""
port       = 3306
# Set during installation
name       = ""
# Set during installation
user       = ""
# Set during installation
pass       = ""
charset    = "utf8mb4"
collation  = "utf8mb4_unicode_ci"
# SQLite: nur 'path' relevant
# path     = "var/database.sqlite"

[security]
# Passwort-Hashing-Algorithmus
algo = "argon2id"
[security.options]
# 64 MB – Minimum für sensible Daten
memory_cost = 65536
# Iterationen
time_cost   = 4
# Parallele Threads
threads     = 2
# Verschlüsselungsschlüssel für API-Keys (Base64, gesetzt während Installation)
encryption_key = ""

[application]
# Hostname ohne Protokoll
domain           = ""
name             = "DeSEC Manager"
# WebAuthn erfordert HTTPS + gültige TLD
webauthn_enabled = true
# Erzwingt HTTPS; nur in Entwicklung auf false setzen
force_https      = true

[theme]
# 'default' = Hellblau+Grün Light/Dark | 'bulma' = klassisches Bulma
name = "default"

# Debug-Modus — niemals in Produktion aktivieren!
debug = false

